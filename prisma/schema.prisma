generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole       @default(STAFF)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  activityLogs  ActivityLog[]
  attendances   Attendance[]
  managedLake   FishingLake[]  @relation("LakeManager")
  notifications Notification[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id          String           @id @default(cuid())
  fullName    String
  phone       String           @unique
  address     String?
  debtBalance Decimal          @default(0) @db.Decimal(12, 2)
  totalSpent  Decimal          @default(0) @db.Decimal(12, 2)
  visitCount  Int              @default(0)
  isVip       Boolean          @default(false)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  sessions    FishingSession[]
  invoices    Invoice[]
}

model FishingLake {
  id          String           @id @default(cuid())
  name        String
  description String?
  address     String?
  managerId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  areas       FishingArea[]
  manager     User?            @relation("LakeManager", fields: [managerId], references: [id])
  sessions    FishingSession[]
}

model FishingArea {
  id          String           @id @default(cuid())
  lakeId      String
  name        String
  capacity    Int              @default(1)
  hourlyRate  Decimal          @db.Decimal(12, 2)
  minDuration Int              @default(1)
  status      AreaStatus       @default(AVAILABLE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lake        FishingLake      @relation(fields: [lakeId], references: [id], onDelete: Cascade)
  sessions    FishingSession[]
}

model FishingSession {
  id            String        @id @default(cuid())
  lakeId        String
  areaId        String
  customerId    String?
  startTime     DateTime      @default(now())
  endTime       DateTime?
  status        SessionStatus @default(ACTIVE)
  hourlyRate    Decimal       @db.Decimal(12, 2)
  totalHours    Float?
  sessionAmount Decimal       @default(0) @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  fishCatches   FishCatch[]
  area          FishingArea   @relation(fields: [areaId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])
  lake          FishingLake   @relation(fields: [lakeId], references: [id])
  invoices      Invoice[]
}

model FishType {
  id           String      @id @default(cuid())
  name         String      @unique
  buybackPrice Decimal     @db.Decimal(12, 2)
  image        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  catches      FishCatch[]
}

model FishCatch {
  id           String         @id @default(cuid())
  sessionId    String
  fishTypeId   String
  weight       Decimal        @db.Decimal(10, 2)
  buybackPrice Decimal        @db.Decimal(12, 2)
  totalAmount  Decimal        @db.Decimal(12, 2)
  isSoldBack   Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  fishType     FishType       @relation(fields: [fishTypeId], references: [id])
  session      FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id           String                 @id @default(cuid())
  categoryId   String
  name         String
  sku          String?                @unique
  barcode      String?                @unique
  description  String?
  price        Decimal                @db.Decimal(12, 2)
  costPrice    Decimal?               @db.Decimal(12, 2)
  stock        Int                    @default(0)
  minStock     Int                    @default(5)
  unit         String                 @default("Cái")
  image        String?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transactions InventoryTransaction[]
  invoiceItems InvoiceItem[]
  category     ProductCategory        @relation(fields: [categoryId], references: [id])
}

model InventoryTransaction {
  id          String    @id @default(cuid())
  productId   String
  type        StockType
  quantity    Int
  note        String?
  performedBy String?
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id])
}

model Invoice {
  id            String          @id @default(cuid())
  invoiceNumber String          @unique
  customerId    String?
  sessionId     String?
  subtotal      Decimal         @db.Decimal(12, 2)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  tax           Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal         @db.Decimal(12, 2)
  status        InvoiceStatus   @default(UNPAID)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  customer      Customer?       @relation(fields: [customerId], references: [id])
  session       FishingSession? @relation(fields: [sessionId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  transactionId String?
  note          String?
  createdAt     DateTime      @default(now())
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  performedBy String?
  createdAt   DateTime @default(now())
}

model Attendance {
  id       String    @id @default(cuid())
  userId   String
  date     DateTime  @default(now())
  checkIn  DateTime
  checkOut DateTime?
  status   String    @default("PRESENT")
  note     String?
  user     User      @relation(fields: [userId], references: [id])
}

model Shift {
  id        String  @id @default(cuid())
  name      String
  startTime String
  endTime   String
  notes     String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  CASHIER
}

enum AreaStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLOSED
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum StockType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  VOID
  REFUNDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  DEBT
}
