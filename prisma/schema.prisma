// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  CASHIER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true)
  
  accounts      Account[]
  sessions      Session[]
  
  // Relations to business logic
  activityLogs  ActivityLog[]
  notifications Notification[]
  attendances   Attendance[]
  managedLake   FishingLake[] @relation("LakeManager")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// BUSINESS DOMAIN: LAKE & SESSIONS
// ==========================================

model Customer {
  id            String           @id @default(cuid())
  fullName      String
  phone         String           @unique
  address       String?
  debtBalance   Decimal          @default(0) @db.Decimal(12, 2)
  totalSpent    Decimal          @default(0) @db.Decimal(12, 2)
  visitCount    Int              @default(0)
  isVip         Boolean          @default(false)
  notes         String?
  
  sessions      FishingSession[]
  invoices      Invoice[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model FishingLake {
  id          String        @id @default(cuid())
  name        String
  description String?
  address     String?
  managerId   String?
  manager     User?         @relation("LakeManager", fields: [managerId], references: [id])
  
  areas       FishingArea[]
  sessions    FishingSession[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model FishingArea {
  id          String           @id @default(cuid())
  lakeId      String
  lake        FishingLake      @relation(fields: [lakeId], references: [id], onDelete: Cascade)
  name        String           // e.g. "Chòi 01", "Khu A"
  capacity    Int              @default(1)
  hourlyRate  Decimal          @db.Decimal(12, 2)
  minDuration Int              @default(1) // in hours
  status      AreaStatus       @default(AVAILABLE)
  
  sessions    FishingSession[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum AreaStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLOSED
}

model FishingSession {
  id            String      @id @default(cuid())
  lakeId        String
  lake          FishingLake @relation(fields: [lakeId], references: [id])
  areaId        String
  area          FishingArea @relation(fields: [areaId], references: [id])
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  
  startTime     DateTime    @default(now())
  endTime       DateTime?
  status        SessionStatus @default(ACTIVE)
  
  // Fees
  hourlyRate    Decimal     @db.Decimal(12, 2)
  totalHours    Float?
  sessionAmount Decimal     @default(0) @db.Decimal(12, 2)
  
  fishCatches   FishCatch[]
  invoices      Invoice[]
  
  notes         String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// ==========================================
// FISH & CATCHES
// ==========================================

model FishType {
  id            String      @id @default(cuid())
  name          String      @unique // Black carp, Grass carp, etc.
  buybackPrice  Decimal     @db.Decimal(12, 2) // Price lake pays to customer per kg
  image         String?
  
  catches       FishCatch[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model FishCatch {
  id            String         @id @default(cuid())
  sessionId     String
  session       FishingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fishTypeId    String
  fishType      FishType       @relation(fields: [fishTypeId], references: [id])
  weight        Decimal        @db.Decimal(10, 2) // in kg
  buybackPrice  Decimal        @db.Decimal(12, 2) // Price at the time of catch
  totalAmount   Decimal        @db.Decimal(12, 2)
  isSoldBack    Boolean        @default(true)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ==========================================
// POS & INVENTORY
// ==========================================

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String              @id @default(cuid())
  categoryId    String
  category      ProductCategory     @relation(fields: [categoryId], references: [id])
  name          String
  sku           String?             @unique
  barcode       String?             @unique
  description   String?
  price         Decimal             @db.Decimal(12, 2)
  costPrice     Decimal?            @db.Decimal(12, 2)
  stock         Int                 @default(0)
  minStock      Int                 @default(5)
  unit          String              @default("Cái")
  image         String?
  isActive      Boolean             @default(true)
  
  invoiceItems  InvoiceItem[]
  transactions  InventoryTransaction[]
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model InventoryTransaction {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  type          StockType
  quantity      Int
  note          String?
  performedBy   String?   // User ID
  
  createdAt     DateTime  @default(now())
}

enum StockType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

// ==========================================
// BILLING & PAYMENTS
// ==========================================

model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique // e.g. INV-2024001
  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id])
  sessionId     String?
  session       FishingSession? @relation(fields: [sessionId], references: [id])
  
  subtotal      Decimal        @db.Decimal(12, 2)
  discount      Decimal        @default(0) @db.Decimal(12, 2)
  tax           Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal        @db.Decimal(12, 2)
  
  status        InvoiceStatus  @default(UNPAID)
  items         InvoiceItem[]
  payments      Payment[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  VOID
  REFUNDED
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String   // For session fees or generic items
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  transactionId String?       // External ref
  note          String?
  
  createdAt     DateTime      @default(now())
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  DEBT
}

// ==========================================
// ACCOUNTING & HR
// ==========================================

model Expense {
  id            String   @id @default(cuid())
  category      String
  description   String
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime @default(now())
  performedBy   String?
  
  createdAt     DateTime @default(now())
}

model Attendance {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  date          DateTime  @default(now())
  checkIn       DateTime
  checkOut      DateTime?
  status        String    @default("PRESENT") // LATE, ABSENT, etc.
  note          String?
}

model Shift {
  id            String    @id @default(cuid())
  name          String
  startTime     String    // "08:00"
  endTime       String    // "17:00"
  notes         String?
}

// ==========================================
// SYSTEM & LOGS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  
  createdAt DateTime @default(now())
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  
  updatedAt   DateTime @updatedAt
}
